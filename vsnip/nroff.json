{
  "single quote": {
    "prefix": "'",
    "body": "\\[${1|aq,oq,cq|}]"
  },
  "double quote": {
    "prefix": "\"",
    "body": "\\[${1|dq,lq,rq|}]"
  },
  "lq": {
    "prefix": "\\*(Lq",
    "body": "\\[lq]"
  },
  "rq": {
    "prefix": "\\*(Rq",
    "body": "\\[rq]"
  },
  "q": {
    "prefix": "\\*(q",
    "body": "\\[dq]"
  }
}
